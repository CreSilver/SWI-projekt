        <mxCell id="kdLZuTw2fMZrOrpVz1Wk-111" parent="1" style="ellipse;whiteSpace=wrap;html=1;" value="Zálohy" vertex="1">
          <mxGeometry height="40" width="50" x="5" y="875" as="geometry" />
        </mxCell>
        <mxCell id="kdLZuTw2fMZrOrpVz1Wk-113" parent="1" style="text;align=center;fontStyle=1;verticalAlign=middle;spacingLeft=3;spacingRight=3;strokeColor=none;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;html=1;" value="UC6" vertex="1">
          <mxGeometry height="20" width="30" x="20" y="861" as="geometry" />
        </mxCell>
        <mxCell id="dcRQVH_oJVEZO6diezTe-4" parent="1" style="text;align=left;fontStyle=1;verticalAlign=middle;spacingLeft=3;spacingRight=3;strokeColor=none;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;html=1;" value="A1 - &lt;span style=&quot;font-weight: normal;&quot;&gt;Obnovení dříve zablokovaného účtu&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;V kroku 4 administrátor vybere u již deaktivovaného uživatele možnost &quot;Obnovení účtu&quot;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;Systém se zeptá na potvrzení akce&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;Po potvrzení systém uživateli opětovně přidělí práva, zaktivní jeho profil a zašle mu&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;email, že jeho účet je opět plně funkční&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;A2 - &lt;span style=&quot;font-weight: 400;&quot;&gt;Provádění systémových záloh (Zálohy)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;V kroku 2 (na Dashboardu) administrátor nevyhledává uživatele, ale přejde do sekce&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;&quot;Údržba a zálohy&quot;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;Administrátor klikne na &quot;Vytvořit novou zálohu&quot;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;Systém zahájí stahování / balení databáze (kurzy, účty, zprávy)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;Po dokončení systém informuje administrátora o úspěšném vytvoření zálohy a zapíše&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;časový údaj do logu&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;A3 - &lt;span style=&quot;font-weight: normal;&quot;&gt;Smazání nebo úprava nevhodného kurzu&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;Pokud problém není v samotném účtu, ale jen ve vytvořeném kurzu, může&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;administrátor v kroku 4 místo uživatele vybrat přímo konkrétní kurz&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;Administrátor kurz upraví (Editace) nebo jej úplně smaže, případně zruší z veřejného&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;výpisu&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="26" width="80" x="349" y="999" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
