        </mxCell>
        <mxCell id="WQ5kGyhv28u5fTmjM_bT-75" parent="1" style="text;align=center;fontStyle=1;verticalAlign=middle;spacingLeft=3;spacingRight=3;strokeColor=none;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;html=1;" value="UC7" vertex="1">
          <mxGeometry height="10" width="40" x="310" y="822" as="geometry" />
        </mxCell>
        <mxCell id="WQ5kGyhv28u5fTmjM_bT-76" parent="1" style="text;align=center;fontStyle=1;verticalAlign=middle;spacingLeft=3;spacingRight=3;strokeColor=none;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;html=1;" value="UC6" vertex="1">
          <mxGeometry height="10" width="40" x="310" y="872" as="geometry" />
        </mxCell>
        <mxCell id="WQ5kGyhv28u5fTmjM_bT-77" parent="1" style="text;align=center;fontStyle=1;verticalAlign=middle;spacingLeft=3;spacingRight=3;strokeColor=none;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;html=1;" value="UC5" vertex="1">
          <mxGeometry height="10" width="40" x="230" y="932" as="geometry" />
        </mxCell>
        <mxCell id="WQ5kGyhv28u5fTmjM_bT-78" parent="1" style="text;align=center;fontStyle=1;verticalAlign=middle;spacingLeft=3;spacingRight=3;strokeColor=none;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;html=1;" value="UC4" vertex="1">
          <mxGeometry height="10" width="40" x="95" y="922" as="geometry" />
        </mxCell>
        <mxCell id="WQ5kGyhv28u5fTmjM_bT-79" parent="1" style="text;align=left;fontStyle=1;verticalAlign=middle;spacingLeft=3;spacingRight=3;strokeColor=none;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;html=1;" value="UC1&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;1) Učitel klikne na tlačítko vytvořit kurz&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;2) Systém vytvoří formulář pro vytvoření kurzu&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;3) Učitel vyplní formulář a klikne na vytvořit&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;4) Systém vytvoří kurz a přidá ho učiteli na účet&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;5) Dále učitel může daný kurz spravovat viz UC2&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;UC2&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;Systém umožní učiteli:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;1) Přidávání, úpravu a odstraňování materiálů - UC8&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;2) Přidávání, úpravu a odstraňování úkolů&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;3) Plánování a vytváření rozvrhu a jeho následná úprava&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;4) Zahájení a ukončení vyučování&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;5) Možnost smazání kurzu&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;UC3&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;1) Po zaplacení kurzu uživatelem, se objeví možnost přímé komunikace&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;2) Možnost privátní komunikace mezi studentem a učitelem&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;UC4&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;1) Učitel má možnost nahlásit uživatele za nevhodné chování&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;2) Učitel má možnost mutovat v callu&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;UC6&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;1) Možnost tvorby úkolů&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;2) Možnost úpravy úkolů&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;3) Možnost hodnocení, přidání komentářů u odevzdaných úkolů&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;4) Možnost zrušení úkolů&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;UC7&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;1) Učitel má možnost tvorby a zrušení hodin&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;2) Učitel může zahájit a ukončit hodinu&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;3) Možnost sdílení obrazovky, ztlumení uživatelů, atd.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;UC9&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;1) Změna informací o kurzu&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="26" width="80" x="400" y="696" as="geometry" />
        </mxCell>
        <mxCell id="2TytaoMagjA9Om0y388l-1" parent="1" style="text;align=center;fontStyle=1;verticalAlign=middle;spacingLeft=3;spacingRight=3;strokeColor=none;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;html=1;" value="&lt;font style=&quot;font-size: 22px;&quot;&gt;&lt;u&gt;Aplikace pro online duočování&lt;/u&gt;&lt;/font&gt;" vertex="1">
