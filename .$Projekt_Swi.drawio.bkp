        <mxCell id="xRVcoeAHJEwT6_EBcB39-89" parent="xRVcoeAHJEwT6_EBcB39-98" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" value="UC9" vertex="1">
          <mxGeometry height="30" width="60" x="341.25" y="356.5" as="geometry" />
        </mxCell>
        <mxCell id="xRVcoeAHJEwT6_EBcB39-90" parent="xRVcoeAHJEwT6_EBcB39-98" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;UC1&lt;/h1&gt;&lt;p&gt;&lt;font face=&quot;Helvetica&quot;&gt;1) Učitel klikne na tlačítko vytvořit kurz&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font face=&quot;Helvetica&quot;&gt;2) Systém zobrazí formulář pro vytvoření kurzu&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font face=&quot;Helvetica&quot;&gt;3)Učitel správně vyplní formulář a klikne na vytvořit&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font face=&quot;Helvetica&quot;&gt;4) Systém vytvoří kurz a přidá ho učiteli na účet&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font face=&quot;Helvetica&quot;&gt;5) Dále učitel může upravovat daný kurz a spravovat ho, viz UC2&lt;/font&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="243" width="265" x="521" y="53" as="geometry" />
        </mxCell>
        <mxCell id="xRVcoeAHJEwT6_EBcB39-91" parent="xRVcoeAHJEwT6_EBcB39-98" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;UC2&lt;/h1&gt;&lt;p&gt;&lt;font face=&quot;Helvetica&quot;&gt;Systém umožní učiteli:&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font face=&quot;Helvetica&quot;&gt;&amp;nbsp; &amp;nbsp;1) Přidání, úpravu a odstranění materiálů -&amp;gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;UC8&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font face=&quot;Helvetica&quot;&gt;&amp;nbsp; &amp;nbsp;2) Přidání, úpravu a odstranění úkolů&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font face=&quot;Helvetica&quot;&gt;&amp;nbsp; &amp;nbsp;3) Plánování a vytváření rozvrhu a jeho&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; následná úprava&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font face=&quot;Helvetica&quot;&gt;&amp;nbsp; &amp;nbsp;4) Zahajování a ukončení vyučování&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font face=&quot;Helvetica&quot;&gt;&amp;nbsp; &amp;nbsp;5) Možnost smazání kurzu&lt;/font&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="243" width="265" x="521" y="263.5" as="geometry" />
        </mxCell>
        <mxCell id="xRVcoeAHJEwT6_EBcB39-92" parent="xRVcoeAHJEwT6_EBcB39-98" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;UC3&lt;/h1&gt;&lt;p&gt;&lt;font face=&quot;Helvetica&quot;&gt;1) Po zaplaceníkurzu uživatelem, se objeví&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; možnost přímé komunikace se studenty&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; (skupinově)&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font face=&quot;Helvetica&quot;&gt;2)&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Po zaplaceníkurzu uživatelem, se objeví&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;možnost přímé komunikace se studenty&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;(skupinově)&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="165" width="265" x="521" y="500" as="geometry" />
        </mxCell>
        <mxCell id="xRVcoeAHJEwT6_EBcB39-93" parent="xRVcoeAHJEwT6_EBcB39-98" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;UC4&lt;/h1&gt;&lt;p&gt;&lt;font face=&quot;Helvetica&quot;&gt;1) Učitel má možnost nahlásit uživatele za nevhodné chování&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font face=&quot;Helvetica&quot;&gt;2)&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Učitel má možnost ztlumovat uživatele v callu&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="117" width="265" x="813" y="55" as="geometry" />
        </mxCell>
        <mxCell id="xRVcoeAHJEwT6_EBcB39-94" parent="xRVcoeAHJEwT6_EBcB39-98" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;UC5&lt;/h1&gt;&lt;p&gt;&lt;font face=&quot;Helvetica&quot;&gt;1) Učitel má možnost zrušit a vymazat kurz&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="77.5" width="265" x="813" y="178.25" as="geometry" />
        </mxCell>
        <mxCell id="xRVcoeAHJEwT6_EBcB39-95" parent="xRVcoeAHJEwT6_EBcB39-98" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;UC6&lt;/h1&gt;&lt;div style=&quot;font-family: Helvetica; font-weight: 700; text-wrap-mode: nowrap;&quot;&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;1) Možnost tvorby úkolů&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;2) Možnost úpravy úkolů&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;3) Možnost hodnocení, přidání komentářů u odevzdaných úkolů&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;4) Možnost zrušení úkolů&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;h1 style=&quot;font-family: &amp;quot;Architects Daughter&amp;quot;; text-wrap-mode: wrap; margin-top: 0px;&quot;&gt;UC7&lt;/h1&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;1) Učitel má možnost tvorby a zrušení hodin&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;2) Učitel může zahájit a ukončit hodinu&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;3) Možnost sdílení obrazovky, ztlumení uživatelů, atd.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;h1 style=&quot;text-wrap-mode: wrap; font-family: &amp;quot;Architects Daughter&amp;quot;; margin-top: 0px;&quot;&gt;UC9&lt;/h1&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;1) Změna informací o kurzu&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="323.5" width="366" x="813" y="263.5" as="geometry" />
        </mxCell>
